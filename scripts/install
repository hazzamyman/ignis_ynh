#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Setting up source files..."

# Download, check integrity, uncompress the Ignis monorepo from manifest.toml
ynh_setup_source --dest_dir="$install_dir"

chown -R "$app:www-data" "$install_dir"

#=================================================
# BUILD THE APP
#=================================================
ynh_script_progression "Installing dependencies and building Ignis (this can take a few minutes)..."

pushd "$install_dir"
    # Full install including dev dependencies (esbuild/svelte), which the build needs.
    ynh_hide_warnings ynh_exec_as_app npm ci --no-audit --no-fund
    # Pinned asar used to extract Obsidian's .asar; explicit dependency, not a live npx.
    ynh_hide_warnings ynh_exec_as_app npm install --no-audit --no-fund --save-exact "@electron/asar@$asar_version"
    # esbuild + esbuild-svelte bundle; no native compilation.
    ynh_hide_warnings ynh_exec_as_app npm run build
popd

#=================================================
# PREPARE DATA DIRECTORY AND DOWNLOAD OBSIDIAN
#=================================================
ynh_script_progression "Downloading and preparing Obsidian..."

# VAULT_ROOT / DATA_ROOT / OBSIDIAN_ASSETS_PATH live under $data_dir so they survive upgrades.
mkdir -p "$data_dir/vaults" "$data_dir/data" "$data_dir/obsidian-app"
chown -R "$app:$app" "$data_dir"

# Obsidian is downloaded, not shipped. It must be present before the service first starts,
# because the server reads obsidian-app/index.html on the very first "/" request.
ignis_setup_obsidian

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

mkdir -p "/var/log/$app"
chown -R "$app:$app" "/var/log/$app"

# Reverse-proxy (with WebSocket support) to the internal Node port.
ynh_config_add_nginx

# Single systemd service running the Node server.
ynh_config_add_systemd

yunohost service add "$app" --description="Browser-based Obsidian client" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start" --wait_until="Server running on"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
