#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

# --full_replace wipes the old tree (including node_modules) so stale files don't linger;
# the data dir is separate and untouched.
ynh_setup_source --dest_dir="$install_dir" --full_replace

chown -R "$app:www-data" "$install_dir"

#=================================================
# REBUILD THE APP
#=================================================
ynh_script_progression "Rebuilding Ignis..."

pushd "$install_dir"
    ynh_hide_warnings ynh_exec_as_app npm ci --no-audit --no-fund
    ynh_hide_warnings ynh_exec_as_app npm install --no-audit --no-fund --save-exact "@electron/asar@$asar_version"
    ynh_hide_warnings ynh_exec_as_app npm run build
popd

#=================================================
# REFRESH OBSIDIAN ASSETS IF THE PINNED VERSION CHANGED
#=================================================
ynh_script_progression "Ensuring Obsidian assets match the pinned version..."

# If this Ignis release bumped $obsidian_version, drop the stale assets so they get
# re-downloaded at the new version. Otherwise ignis_setup_obsidian is a no-op.
if [ -f "$data_dir/obsidian-app/package.json" ]; then
    current_ob="$(node -e "try{process.stdout.write(require('$data_dir/obsidian-app/package.json').version||'')}catch(e){}" 2>/dev/null || true)"
    if [ -n "$current_ob" ] && [ "$current_ob" != "$obsidian_version" ]; then
        ynh_print_info "Obsidian changed ($current_ob -> $obsidian_version); refreshing assets."
        ynh_safe_rm "$data_dir/obsidian-app"
    fi
fi

mkdir -p "$data_dir/vaults" "$data_dir/data" "$data_dir/obsidian-app"
chown -R "$app:$app" "$data_dir"

ignis_setup_obsidian

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

mkdir -p "/var/log/$app"
chown -R "$app:$app" "/var/log/$app"

ynh_config_add_nginx
ynh_config_add_systemd

yunohost service add "$app" --description="Browser-based Obsidian client" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start" --wait_until="Server running on"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
